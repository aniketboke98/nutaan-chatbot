// Learn more about Prisma schema: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// Shopify session model for @shopify/shopify-app-session-storage-prisma
// IMPORTANT: Do NOT use @db.ObjectId — Shopify passes non-ObjectId string IDs
// (e.g. "offline_mystore.myshopify.com"). Using @db.ObjectId would break storage.
model Session {
  id                  String    @id @map("_id")
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}
